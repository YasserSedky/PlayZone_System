2025-10-06 10:23:28,109 - database - INFO - تنفيذ استعلام: SELECT 
                    COUNT(*) as total_shifts,
                    COUNT(CASE WHEN s.status = 'completed' THEN 1 END) as completed_shifts,
                    COUNT(CASE WHEN s.status = 'active' THEN 1 END) as active_shifts,
                    COALESCE(AVG(julianday(s.end_time) - julianday(s.start_time)) * 24, 0) as avg_shift_hours,
                    COALESCE(SUM(i.total_amount), 0) as total_revenue,
                    COALESCE(SUM(e.amount), 0) as total_expenses
                FROM shifts s
                LEFT JOIN invoices i ON s.id = i.shift_id
                LEFT JOIN expenses e ON s.id = e.shift_id
                WHERE DATE(s.start_time) BETWEEN ? AND ?
