2025-10-06 11:23:02,510 - database - INFO - تنفيذ استعلام: SELECT 
                s.id,
                s.shift_name,
                s.start_time,
                s.end_time,
                s.status,
                u.username as cashier_name,
                COUNT(i.id) as invoice_count,
                COALESCE(SUM(i.total_amount), 0) as total_revenue,
                COALESCE(SUM(e.amount), 0) as total_expenses
            FROM shifts s
            LEFT JOIN users u ON s.cashier_id = u.id
            LEFT JOIN invoices i ON s.id = i.shift_id
            LEFT JOIN expenses e ON s.id = e.shift_id
            WHERE DATE(s.start_time) BETWEEN ? AND ? GROUP BY s.id, s.shift_name, s.start_time, s.end_time, s.status, u.username
                        ORDER BY s.start_time DESC
